<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — GoalZone</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700;800;900&family=Barlow:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg: #080d18;
            --bg2: #0c1220;
            --card: #111827;
            --card2: #16202f;
            --elevated: #1c2d42;
            --green: #00e676;
            --blue: #2979ff;
            --live: #ff1744;
            --gold: #ffd600;
            --yellow: #ffc107;
            --red: #f44336;
            --t1: #eef2ff;
            --t2: #7b96c4;
            --t3: #3d5478;
            --border: #1a2640;
            --r1: 8px;
            --r2: 12px;
            --r3: 16px;
            --shadow: 0 4px 24px rgba(0,0,0,.5);
            --tr: all .22s cubic-bezier(.4,0,.2,1);
            --fd: 'Barlow Condensed',sans-serif;
            --fb: 'Barlow',sans-serif;
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        html {
            scroll-behavior: smooth
        }

        body {
            font-family: var(--fb);
            background: var(--bg);
            color: var(--t1);
            min-height: 100vh;
            background-image: radial-gradient(ellipse at 15% 0%,rgba(41,121,255,.07) 0%,transparent 55%), radial-gradient(ellipse at 85% 0%,rgba(0,230,118,.04) 0%,transparent 50%)
        }

        ::-webkit-scrollbar {
            width: 5px
        }

        ::-webkit-scrollbar-track {
            background: var(--bg)
        }

        ::-webkit-scrollbar-thumb {
            background: var(--elevated);
            border-radius: 3px
        }

        a {
            text-decoration: none;
            color: inherit
        }

        img {
            display: block
        }
        /* NAVBAR */
        .nb {
            background: rgba(8,13,24,.96);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 2px 24px rgba(0,0,0,.5)
        }

        .nb-inner {
            max-width: 1120px;
            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 14px 0
        }

        .brand-ico {
            width: 34px;
            height: 34px;
            background: linear-gradient(135deg,var(--green),var(--blue));
            border-radius: 7px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 17px
        }

        .brand-txt {
            font-family: var(--fd);
            font-size: 21px;
            font-weight: 800;
            letter-spacing: 1px
        }

            .brand-txt span {
                color: var(--green)
            }

        .nav-links {
            display: flex
        }

        .nl {
            font-family: var(--fd);
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--t2);
            padding: 22px 15px;
            position: relative;
            transition: var(--tr)
        }

            .nl::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 15px;
                right: 15px;
                height: 2px;
                background: var(--green);
                transform: scaleX(0);
                transition: var(--tr)
            }

            .nl:hover, .nl.active {
                color: var(--t1)
            }

                .nl:hover::after, .nl.active::after {
                    transform: scaleX(1)
                }

        .nb-icons {
            display: flex;
            align-items: center;
            gap: 5px
        }

        .ico-btn {
            width: 36px;
            height: 36px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r1);
            color: var(--t2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            transition: var(--tr)
        }

            .ico-btn:hover {
                background: var(--elevated);
                color: var(--t1);
                border-color: var(--blue)
            }

        .tog {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r1);
            padding: 7px 9px;
            color: var(--t1);
            cursor: pointer;
            line-height: 1
        }

        .mob-menu {
            max-height: 0;
            overflow: hidden;
            transition: max-height .3s ease
        }

            .mob-menu.open {
                max-height: 320px
            }

            .mob-menu .nl {
                padding: 14px 0;
                border-bottom: 1px solid var(--border);
                display: block
            }

        .wrap {
            max-width: 1120px;
            margin: 0 auto;
            padding: 0 20px
        }
        /* FOOTER */
        .ft {
            background: var(--bg2);
            border-top: 1px solid var(--border);
            padding: 44px 0 22px;
            margin-top: 36px
        }

        .ft-brand {
            font-family: var(--fd);
            font-size: 20px;
            font-weight: 800;
            margin-bottom: 8px
        }

            .ft-brand span {
                color: var(--green)
            }

        .ft-desc {
            font-size: 12px;
            color: var(--t3);
            line-height: 1.7;
            max-width: 240px
        }

        .ft-h {
            font-family: var(--fd);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--t2);
            margin-bottom: 14px
        }

        .ft-ul {
            list-style: none;
            padding: 0
        }

            .ft-ul li {
                margin-bottom: 7px
            }

            .ft-ul a {
                color: var(--t3);
                font-size: 12px;
                transition: var(--tr)
            }

                .ft-ul a:hover {
                    color: var(--t1)
                }

        .si-row {
            display: flex;
            gap: 7px;
            margin-top: 14px
        }

        .si {
            width: 34px;
            height: 34px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r1);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--t3);
            transition: var(--tr);
            font-size: 13px
        }

            .si:hover {
                background: var(--elevated);
                color: var(--green);
                border-color: var(--green)
            }

        .ft-bot {
            border-top: 1px solid var(--border);
            padding-top: 18px;
            margin-top: 32px;
            font-size: 11px;
            color: var(--t3);
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 6px
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>

    <!-- NAVBAR -->
    <nav class="nb">
        <div class="nb-inner">
            <a asp-controller="Home" asp-action="Index" class="brand">
                <div class="brand-ico">⚽</div>
                <span class="brand-txt">Goal<span>Zone</span></span>
            </a>
            <div class="nav-links d-none d-lg-flex">
                <a asp-controller="Match" asp-action="MatchList"
                   class="nl @(ViewData["ActivePage"]?.ToString() == "Home" ? "active" : "")">Ana Sayfa</a>
                <a asp-controller="Home" asp-action="Index"
                   class="nl @(ViewData["ActivePage"]?.ToString() == "Live" ? "active" : "")">Canlı Skorlar</a>
                <a asp-controller="Fixture" asp-action="Index"
                   class="nl @(ViewData["ActivePage"]?.ToString() == "Fixtures" ? "active" : "")">Fikstür</a>
                <a asp-controller="Team" asp-action="TeamList"
                   class="nl @(ViewData["ActivePage"]?.ToString() == "Standings" ? "active" : "")">
                    Puan Durumu
                </a>
                <a href="#" class="nl">Ligler</a>
            </div>
            <div class="nb-icons">
                <a href="#" class="ico-btn d-none d-sm-flex"><i class="bi bi-search"></i></a>
                <a href="#" class="ico-btn d-none d-sm-flex"><i class="bi bi-bell"></i></a>
                <a href="#" class="ico-btn"><i class="bi bi-person"></i></a>
                <button class="tog d-lg-none" id="tog"><i class="bi bi-list"></i></button>
            </div>
        </div>
        <div class="mob-menu" id="mobMenu">
            <div class="wrap">
                <a asp-controller="Home" asp-action="Index" class="nl d-block">Ana Sayfa</a>
                <a asp-controller="Home" asp-action="Index" class="nl d-block">Canlı Skorlar</a>
                <a asp-controller="Fixtures" asp-action="Index" class="nl d-block">Fikstür</a>
                <a href="#" class="nl d-block">Puan Durumu</a>
                <a href="#" class="nl d-block">Ligler</a>
            </div>
        </div>
    </nav>

    @RenderBody()

    <!-- FOOTER -->
    <footer class="ft">
        <div class="wrap">
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="ft-brand">Goal<span>Zone</span></div>
                    <p class="ft-desc">Premier futbol liglerinin canlı skorları, maç analizleri ve istatistikleri için tek adres.</p>
                    <div class="si-row">
                        <a href="#" class="si"><i class="bi bi-twitter-x"></i></a>
                        <a href="#" class="si"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="si"><i class="bi bi-youtube"></i></a>
                        <a href="#" class="si"><i class="bi bi-telegram"></i></a>
                    </div>
                </div>
                <div class="col-6 col-lg-2">
                    <div class="ft-h">Ligler</div>
                    <ul class="ft-ul">
                        <li><a href="#">Premier League</a></li>
                        <li><a href="#">La Liga</a></li>
                        <li><a href="#">Bundesliga</a></li>
                        <li><a href="#">Serie A</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-2">
                    <div class="ft-h">Hızlı Erişim</div>
                    <ul class="ft-ul">
                        <li><a asp-controller="Home" asp-action="Index">Haftalık Skorlar</a></li>
                        <li><a asp-controller="Fixtures" asp-action="Index">Fikstür</a></li>
                        <li><a href="#">Puan Durumu</a></li>
                        <li><a href="#">Gol Krallığı</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-2">
                    <div class="ft-h">Takımlar</div>
                    <ul class="ft-ul">
                        <li><a href="#">Arsenal</a></li>
                        <li><a href="#">Liverpool</a></li>
                        <li><a href="#">Man City</a></li>
                        <li><a href="#">Chelsea</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-2">
                    <div class="ft-h">Destek</div>
                    <ul class="ft-ul">
                        <li><a href="#">Hakkımızda</a></li>
                        <li><a href="#">İletişim</a></li>
                        <li><a href="#">Gizlilik</a></li>
                        <li><a href="#">Kullanım Şartları</a></li>
                    </ul>
                </div>
            </div>
            <div class="ft-bot">
                <span>© 2025 GoalZone. Tüm hakları saklıdır.</span>
                <span>Premier League verileri demo amaçlıdır.</span>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const tog = document.getElementById('tog');
        const mob = document.getElementById('mobMenu');
        tog.addEventListener('click', () => {
            mob.classList.toggle('open');
            tog.innerHTML = mob.classList.contains('open')
                ? '<i class="bi bi-x-lg"></i>' : '<i class="bi bi-list"></i>';
        });
        window.addEventListener('scroll', () => {
            document.querySelector('.nb').style.boxShadow =
                window.scrollY > 8 ? '0 4px 32px rgba(0,0,0,.7)' : '0 2px 24px rgba(0,0,0,.5)';
        });
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
