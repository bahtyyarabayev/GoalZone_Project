@{
    Layout = "_Layout";
    ViewData["Title"] = "İstatistik Ekle";
    var fixtures = ViewBag.Fixtures as List<GoalZonePremierLig.Web.Api.Dtos.FixtureDtos.ResultFixtureDto> ?? new();
}

@section Styles {
    <style>
        .admin-head {
            background: linear-gradient(135deg,var(--bg2),var(--card));
            border-bottom: 1px solid var(--border);
            padding: 28px 0 20px
        }

        .admin-badge {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: rgba(0,230,118,.1);
            border: 1px solid rgba(0,230,118,.25);
            border-radius: 20px;
            padding: 4px 12px;
            font-family: var(--fd);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1px;
            color: var(--green);
            text-transform: uppercase;
            margin-bottom: 10px
        }

        .admin-title {
            font-family: var(--fd);
            font-size: clamp(22px,4vw,36px);
            font-weight: 900;
            line-height: 1
        }

        .form-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r3);
            padding: 28px;
            margin-bottom: 18px
        }

        .fc-title {
            font-family: var(--fd);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--t3);
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            gap: 10px
        }

            .fc-title::after {
                content: '';
                flex: 1;
                height: 1px;
                background: var(--border)
            }

        .form-label {
            font-family: var(--fd);
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: var(--t2);
            margin-bottom: 6px
        }

        .form-control, .form-select {
            background: var(--elevated) !important;
            border: 1px solid var(--border) !important;
            color: var(--t1) !important;
            border-radius: var(--r1) !important;
            font-family: var(--fd) !important;
            font-size: 15px !important;
            padding: 10px 14px !important
        }

            .form-control:focus, .form-select:focus {
                border-color: var(--blue) !important;
                box-shadow: 0 0 0 3px rgba(41,121,255,.15) !important
            }

            .form-control::placeholder {
                color: var(--t3) !important
            }

            .form-select option {
                background: var(--card);
                color: var(--t1)
            }

        .btn-submit {
            background: linear-gradient(135deg,var(--green),#00c853);
            border: none;
            color: #000;
            font-family: var(--fd);
            font-size: 14px;
            font-weight: 800;
            letter-spacing: 1px;
            text-transform: uppercase;
            padding: 12px 32px;
            border-radius: var(--r2);
            transition: var(--tr);
            cursor: pointer
        }

            .btn-submit:hover {
                transform: translateY(-1px);
                box-shadow: 0 8px 24px rgba(0,230,118,.3)
            }

        .stat-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-bottom: 12px
        }

        .stat-header {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-bottom: 8px
        }

        .stat-label {
            font-family: var(--fd);
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--t3);
            text-align: center;
            padding: 6px;
            background: var(--elevated);
            border-radius: var(--r1)
        }

            .stat-label.home {
                color: var(--blue)
            }

            .stat-label.away {
                color: var(--live)
            }

        .stat-name {
            font-family: var(--fd);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: var(--t3);
            text-align: center;
            padding: 14px 0 4px
        }

        .match-info {
            background: var(--elevated);
            border: 1px solid var(--border);
            border-radius: var(--r2);
            padding: 14px 18px;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            justify-content: space-between
        }

        .mi-team {
            font-family: var(--fd);
            font-size: 16px;
            font-weight: 800
        }

        .mi-vs {
            font-family: var(--fd);
            font-size: 13px;
            font-weight: 700;
            color: var(--t3)
        }

        .mi-week {
            font-size: 11px;
            color: var(--t3)
        }

        .alert-success-custom {
            background: rgba(0,230,118,.08);
            border: 1px solid rgba(0,230,118,.25);
            color: var(--green);
            border-radius: var(--r2);
            padding: 14px 18px;
            margin-bottom: 20px;
            font-family: var(--fd);
            font-size: 14px;
            font-weight: 700
        }

        .alert-error-custom {
            background: rgba(255,23,68,.08);
            border: 1px solid rgba(255,23,68,.25);
            color: var(--live);
            border-radius: var(--r2);
            padding: 14px 18px;
            margin-bottom: 20px;
            font-family: var(--fd);
            font-size: 14px;
            font-weight: 700
        }
    </style>
}

    <section class="admin-head">
        <div class="wrap">
            <div class="admin-badge"><i class="bi bi-graph-up"></i> Admin Panel</div>
            <h1 class="admin-title">İstatistik <span style="color:var(--green)">Ekle</span></h1>
        </div>
    </section>

    <main>
        <div class="wrap" style="padding-top:28px;padding-bottom:56px">

        @if (TempData["Success"] != null)
        {
            <div class="alert-success-custom"><i class="bi bi-check-circle me-2"></i>@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert-error-custom"><i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]</div>
        }

        <form method="post" asp-action="AddStatistic" asp-controller="Admin">
            <input type="hidden" name="HomeTeamId" id="homeTeamIdInput" />
            <input type="hidden" name="AwayTeamId" id="awayTeamIdInput" />

            <div class="row g-4">
                <div class="col-12">
                    <div class="form-card">
                        <div class="fc-title"><i class="bi bi-calendar-event" style="color:var(--gold)"></i> Maç Seç</div>
                        <select name="FixtureId" id="fixtureSelect" class="form-select" required onchange="updateMatchInfo(this)">
                            <option value="">— Maç Seçin —</option>
                            @foreach (var f in fixtures)
                            {
                                <option value="@f.MatchId"
                                    data-home="@f.HomeTeam"
                                    data-away="@f.AwayTeam"
                                    data-homeid="@f.HomeTeamId"
                                    data-awayid="@f.AwayTeamId"
                                    data-week="@f.Week"
                                    data-date="@f.MatchDate.ToString("dd MMM yyyy")">
                                    @f.Week — @f.HomeTeam vs @f.AwayTeam (@f.MatchDate.ToString("dd MMM"))
                                </option>
                            }
                        </select>

                        <div class="match-info mt-3" id="matchInfo" style="display:none">
                            <div>
                                <div class="mi-team" id="miHome">—</div>
                                <div class="mi-week" id="miDate"></div>
                            </div>
                            <div class="mi-vs">VS</div>
                            <div style="text-align:right">
                                <div class="mi-team" id="miAway">—</div>
                                <div class="mi-week" id="miWeek"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <div class="form-card">
                        <div class="fc-title"><i class="bi bi-bar-chart-fill" style="color:var(--green)"></i> İstatistikler</div>

                        <!-- Header -->
                        <div class="stat-header">
                            <div class="stat-label home"><i class="bi bi-house-fill me-1"></i><span id="homeLabel">Ev Sahibi</span></div>
                            <div class="stat-label away"><span id="awayLabel">Deplasman</span><i class="bi bi-airplane-fill ms-1"></i></div>
                        </div>

                        <!-- Topa Sahip Olma -->
                        <div class="stat-name">⚽ Topa Sahip Olma (%)</div>
                        <div class="stat-row">
                            <input type="number" name="HomePossession" class="form-control" placeholder="55" min="0" max="100" step="0.1" required />
                            <input type="number" name="AwayPossession" class="form-control" placeholder="45" min="0" max="100" step="0.1" required />
                        </div>

                        <!-- Şut -->
                        <div class="stat-name">🎯 Şut</div>
                        <div class="stat-row">
                            <input type="number" name="HomeShots" class="form-control" placeholder="14" min="0" required />
                            <input type="number" name="AwayShots" class="form-control" placeholder="10" min="0" required />
                        </div>

                        <!-- İsabetli Şut -->
                        <div class="stat-name">🎯 İsabetli Şut</div>
                        <div class="stat-row">
                            <input type="number" name="HomeShotsOnTarget" class="form-control" placeholder="6" min="0" required />
                            <input type="number" name="AwayShotsOnTarget" class="form-control" placeholder="4" min="0" required />
                        </div>

                        <!-- Pas -->
                        <div class="stat-name">🔄 Pas</div>
                        <div class="stat-row">
                            <input type="number" name="HomePasses" class="form-control" placeholder="512" min="0" required />
                            <input type="number" name="AwayPasses" class="form-control" placeholder="438" min="0" required />
                        </div>

                        <!-- İsabetli Pas -->
                        <div class="stat-name">✅ İsabetli Pas</div>
                        <div class="stat-row">
                            <input type="number" name="HomeAccuratePasses" class="form-control" placeholder="441" min="0" required />
                            <input type="number" name="AwayAccuratePasses" class="form-control" placeholder="371" min="0" required />
                        </div>

                        <!-- Korner -->
                        <div class="stat-name">🚩 Korner</div>
                        <div class="stat-row">
                            <input type="number" name="HomeCorners" class="form-control" placeholder="7" min="0" required />
                            <input type="number" name="AwayCorners" class="form-control" placeholder="4" min="0" required />
                        </div>

                        <!-- Faul -->
                        <div class="stat-name">🟨 Faul</div>
                        <div class="stat-row">
                            <input type="number" name="HomeFouls" class="form-control" placeholder="12" min="0" required />
                            <input type="number" name="AwayFouls" class="form-control" placeholder="9" min="0" required />
                        </div>

                        <!-- Ofsayt -->
                        <div class="stat-name">🚫 Ofsayt</div>
                        <div class="stat-row" style="margin-bottom:0">
                            <input type="number" name="HomeOffsides" class="form-control" placeholder="3" min="0" required />
                            <input type="number" name="AwayOffsides" class="form-control" placeholder="2" min="0" required />
                        </div>
                    </div>
                </div>

                <div class="col-12">
                    <button type="submit" class="btn-submit w-100">
                        <i class="bi bi-graph-up me-2"></i> İstatistikleri Kaydet
                    </button>
                </div>
            </div>
        </form>
    </div>
</main>

@section Scripts {
    <script>
        function updateMatchInfo(select) {
            const opt = select.options[select.selectedIndex];
            if (!opt.value) {
                document.getElementById('matchInfo').style.display = 'none';
                return;
            }
            document.getElementById('miHome').textContent = opt.dataset.home;
            document.getElementById('miAway').textContent = opt.dataset.away;
            document.getElementById('miWeek').textContent = opt.dataset.week;
            document.getElementById('miDate').textContent = opt.dataset.date;
            document.getElementById('homeLabel').textContent = opt.dataset.home;
            document.getElementById('awayLabel').textContent = opt.dataset.away;
            document.getElementById('homeTeamIdInput').value = opt.dataset.homeid;
            document.getElementById('awayTeamIdInput').value = opt.dataset.awayid;
            document.getElementById('matchInfo').style.display = 'flex';
        }
    </script>
}

