@model GoalZonePremierLig.UI.Models.FixtureModel
@{
    Layout = "_Layout";
    var week = ViewBag.Week as string ?? "34.Hafta";

    var fixtures = Model?.Fixtures;
    var grouped = fixtures != null
        ? fixtures.GroupBy(f => f.MatchDate.Date).OrderBy(g => g.Key).ToList()
        : new List<System.Linq.IGrouping<DateTime, GoalZonePremierLig.Web.Api.Dtos.FixtureDtos.ResultFixtureDto>>();

    var summary = Model?.Summary;
    int weekNum = 0;
    int.TryParse(new string(week.TakeWhile(char.IsDigit).ToArray()), out weekNum);
    int prevWeek = weekNum > 1 ? weekNum - 1 : weekNum;
    int nextWeek = weekNum + 1;

    string DayName(DateTime d) => d.DayOfWeek switch
    {
        DayOfWeek.Monday => "Pazartesi",
        DayOfWeek.Tuesday => "Salı",
        DayOfWeek.Wednesday => "Çarşamba",
        DayOfWeek.Thursday => "Perşembe",
        DayOfWeek.Friday => "Cuma",
        DayOfWeek.Saturday => "Cumartesi",
        DayOfWeek.Sunday => "Pazar",
        _ => ""
    };
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Fikstür — GoalZone @week</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;500;600;700;800;900&family=Barlow:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --bg: #080d18;
            --bg2: #0c1220;
            --card: #111827;
            --card2: #16202f;
            --elevated: #1c2d42;
            --green: #00e676;
            --blue: #2979ff;
            --live: #ff1744;
            --gold: #ffd600;
            --yellow: #ffc107;
            --red: #f44336;
            --t1: #eef2ff;
            --t2: #7b96c4;
            --t3: #3d5478;
            --border: #1a2640;
            --r1: 8px;
            --r2: 12px;
            --r3: 16px;
            --tr: all .22s cubic-bezier(.4,0,.2,1);
            --fd: 'Barlow Condensed',sans-serif;
            --fb: 'Barlow',sans-serif;
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0
        }

        html {
            scroll-behavior: smooth
        }

        body {
            font-family: var(--fb);
            background: var(--bg);
            color: var(--t1);
            min-height: 100vh;
            background-image: radial-gradient(ellipse at 15% 0%,rgba(41,121,255,.07) 0%,transparent 55%), radial-gradient(ellipse at 85% 0%,rgba(0,230,118,.04) 0%,transparent 50%)
        }

        ::-webkit-scrollbar {
            width: 5px
        }

        ::-webkit-scrollbar-track {
            background: var(--bg)
        }

        ::-webkit-scrollbar-thumb {
            background: var(--elevated);
            border-radius: 3px
        }

        a {
            text-decoration: none;
            color: inherit
        }

        img {
            display: block
        }

        /* ── NAVBAR ── */
        .nb {
            background: rgba(8,13,24,.96);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 2px 24px rgba(0,0,0,.5)
        }

        .nb-inner {
            max-width: 1120px;
            margin: 0 auto;
            padding: 0 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 14px 0
        }

        .brand-ico {
            width: 34px;
            height: 34px;
            background: linear-gradient(135deg,var(--green),var(--blue));
            border-radius: 7px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 17px
        }

        .brand-txt {
            font-family: var(--fd);
            font-size: 21px;
            font-weight: 800;
            letter-spacing: 1px
        }

            .brand-txt span {
                color: var(--green)
            }

        .nav-links {
            display: flex
        }

        .nl {
            font-family: var(--fd);
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--t2);
            padding: 22px 15px;
            position: relative;
            transition: var(--tr)
        }

            .nl::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 15px;
                right: 15px;
                height: 2px;
                background: var(--green);
                transform: scaleX(0);
                transition: var(--tr)
            }

            .nl:hover, .nl.active {
                color: var(--t1)
            }

                .nl:hover::after, .nl.active::after {
                    transform: scaleX(1)
                }

        .nb-icons {
            display: flex;
            align-items: center;
            gap: 5px
        }

        .ico-btn {
            width: 36px;
            height: 36px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r1);
            color: var(--t2);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            transition: var(--tr)
        }

            .ico-btn:hover {
                background: var(--elevated);
                color: var(--t1);
                border-color: var(--blue)
            }

        .tog {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r1);
            padding: 7px 9px;
            color: var(--t1);
            cursor: pointer;
            line-height: 1
        }

        .mob-menu {
            max-height: 0;
            overflow: hidden;
            transition: max-height .3s ease
        }

            .mob-menu.open {
                max-height: 320px
            }

            .mob-menu .nl {
                padding: 14px 0;
                border-bottom: 1px solid var(--border);
                display: block
            }

        .wrap {
            max-width: 1120px;
            margin: 0 auto;
            padding: 0 20px
        }

        /* ── PAGE HEADER ── */
        .pg-head {
            background: linear-gradient(135deg,var(--bg2),var(--card));
            border-bottom: 1px solid var(--border);
            padding: 32px 0 24px;
            position: relative;
            overflow: hidden
        }

            .pg-head::before {
                content: '';
                position: absolute;
                top: -40%;
                right: -5%;
                width: 380px;
                height: 380px;
                background: radial-gradient(circle,rgba(41,121,255,.05) 0%,transparent 70%);
                pointer-events: none
            }

        .pg-badge {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: rgba(255,214,0,.09);
            border: 1px solid rgba(255,214,0,.22);
            border-radius: 20px;
            padding: 4px 12px;
            font-family: var(--fd);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 1px;
            color: var(--gold);
            text-transform: uppercase;
            margin-bottom: 10px
        }

        .pg-title {
            font-family: var(--fd);
            font-size: clamp(26px,5vw,42px);
            font-weight: 900;
            letter-spacing: .5px;
            line-height: 1
        }

        .pg-sub {
            font-size: 13px;
            color: var(--t2);
            margin-top: 6px
        }

        /* ── WEEK NAV ── */
        .week-nav {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-top: 16px;
            flex-wrap: wrap
        }

        .wn-btn {
            display: flex;
            align-items: center;
            gap: 6px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r1);
            padding: 8px 14px;
            font-family: var(--fd);
            font-size: 12px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            color: var(--t2);
            cursor: pointer;
            transition: var(--tr);
            text-decoration: none
        }

            .wn-btn:hover {
                background: var(--elevated);
                color: var(--t1);
                border-color: var(--blue)
            }

        .wn-cur {
            font-family: var(--fd);
            font-size: 16px;
            font-weight: 800;
            color: var(--t1);
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r1);
            padding: 8px 20px;
            letter-spacing: .5px
        }

        /* ── WEEK SUMMARY ── */
        .week-summary {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 12px;
            margin-bottom: 24px
        }

        .ws-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r2);
            padding: 16px;
            text-align: center
        }

        .ws-num {
            font-family: var(--fd);
            font-size: 26px;
            font-weight: 900;
            line-height: 1
        }

        .ws-lbl {
            font-size: 11px;
            color: var(--t3);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-top: 4px;
            font-weight: 600
        }

        /* ── DAY GROUP ── */
        .day-group {
            margin-bottom: 28px
        }

        .day-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 12px
        }

        .day-title {
            font-family: var(--fd);
            font-size: 13px;
            font-weight: 800;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--t2)
        }

        .day-date {
            font-family: var(--fd);
            font-size: 12px;
            color: var(--t3);
            letter-spacing: 1px
        }

        .day-line {
            flex: 1;
            height: 1px;
            background: var(--border)
        }

        .day-cnt {
            font-family: var(--fd);
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1px;
            text-transform: uppercase;
            padding: 3px 10px;
            border-radius: 8px;
            white-space: nowrap;
            background: rgba(41,121,255,.1);
            border: 1px solid rgba(41,121,255,.2);
            color: var(--blue)
        }

        /* ── FIXTURE CARD ── */
        .fx-card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r2);
            padding: 0;
            margin-bottom: 8px;
            overflow: hidden;
            transition: var(--tr);
            position: relative;
            display: block;
            text-decoration: none;
            color: inherit
        }

            .fx-card:hover {
                background: var(--card2);
                border-color: rgba(41,121,255,.3);
                transform: translateY(-1px);
                box-shadow: 0 6px 24px rgba(0,0,0,.4);
                color: inherit
            }

            .fx-card.featured {
                border-color: rgba(255,214,0,.22);
                background: linear-gradient(135deg,var(--card),rgba(255,214,0,.03))
            }

                .fx-card.featured:hover {
                    border-color: rgba(255,214,0,.4)
                }

            .fx-card.live-card {
                border-color: rgba(255,23,68,.25)
            }

        .fx-top-badge {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg,var(--gold),transparent)
        }

        .fx-live-badge {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: linear-gradient(90deg,var(--live),transparent)
        }

        .fx-inner {
            display: flex;
            align-items: center;
            padding: 14px 18px;
            gap: 0
        }

        /* time column */
        .fx-time-col {
            width: 72px;
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px
        }

        .fx-time {
            font-family: var(--fd);
            font-size: 16px;
            font-weight: 700;
            color: var(--t2)
        }

            .fx-time.live-time {
                color: var(--live);
                animation: blink 1.4s infinite
            }

        @@keyframes blink {
            0%, 100% {
                opacity: 1
            }

            50% {
                opacity: .5
            }
        }

        .fx-top-tag {
            font-family: var(--fd);
            font-size: 9px;
            font-weight: 800;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: var(--gold);
            background: rgba(255,214,0,.08);
            border: 1px solid rgba(255,214,0,.2);
            padding: 2px 8px;
            border-radius: 7px
        }

        .fx-live-tag {
            font-family: var(--fd);
            font-size: 9px;
            font-weight: 800;
            letter-spacing: 1px;
            color: var(--live);
            background: rgba(255,23,68,.1);
            border: 1px solid rgba(255,23,68,.25);
            padding: 2px 8px;
            border-radius: 7px;
            animation: blink 1.4s infinite
        }

        .fx-status-tag {
            font-family: var(--fd);
            font-size: 9px;
            font-weight: 700;
            letter-spacing: .8px;
            color: var(--t3);
            text-transform: uppercase
        }

        .fx-divider {
            width: 1px;
            height: 44px;
            background: var(--border);
            margin: 0 16px;
            flex-shrink: 0
        }

        /* teams */
        .fx-teams {
            flex: 1;
            min-width: 0;
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            align-items: center;
            gap: 8px
        }

        .fx-team-home {
            display: flex;
            align-items: center;
            gap: 10px;
            justify-content: flex-end
        }

        .fx-team-away {
            display: flex;
            align-items: center;
            gap: 10px
        }

        .fx-name {
            font-family: var(--fd);
            font-size: 16px;
            font-weight: 700;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis
        }

            .fx-name.home {
                text-align: right
            }

        .fx-logo {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: var(--elevated);
            border: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: var(--fd);
            font-size: 9px;
            font-weight: 800;
            color: var(--t2);
            overflow: hidden;
            flex-shrink: 0
        }

            .fx-logo img {
                width: 100%;
                height: 100%;
                object-fit: contain;
                padding: 3px
            }

        .vs-block {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 2px;
            flex-shrink: 0
        }

        .vs-text {
            font-family: var(--fd);
            font-size: 13px;
            font-weight: 800;
            color: var(--t3)
        }
        /* SKOR */
        .score-block {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 2px;
            flex-shrink: 0
        }

        .score-txt {
            font-family: var(--fd);
            font-size: 22px;
            font-weight: 900;
            letter-spacing: -1px;
            color: #fff;
            line-height: 1
        }

            .score-txt.live-score {
                color: var(--green)
            }

        .score-min {
            font-family: var(--fd);
            font-size: 10px;
            color: var(--live);
            font-weight: 700
        }

        /* right */
        .fx-right {
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 6px;
            margin-left: 14px;
            flex-shrink: 0
        }

        .fx-stadium {
            font-size: 11px;
            color: var(--t3);
            text-align: right;
            max-width: 150px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis
        }

        /* ── CONTENT ── */
        .content {
            padding: 28px 0 56px
        }

        /* ── EMPTY STATE ── */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: var(--t3)
        }

            .empty-state i {
                font-size: 40px;
                display: block;
                margin-bottom: 12px;
                opacity: .3
            }

        /* ── FOOTER ── */
        .ft {
            background: var(--bg2);
            border-top: 1px solid var(--border);
            padding: 44px 0 22px;
            margin-top: 0
        }

        .ft-brand {
            font-family: var(--fd);
            font-size: 20px;
            font-weight: 800;
            margin-bottom: 8px
        }

            .ft-brand span {
                color: var(--green)
            }

        .ft-desc {
            font-size: 12px;
            color: var(--t3);
            line-height: 1.7;
            max-width: 240px
        }

        .ft-h {
            font-family: var(--fd);
            font-size: 11px;
            font-weight: 700;
            letter-spacing: 2px;
            text-transform: uppercase;
            color: var(--t2);
            margin-bottom: 14px
        }

        .ft-ul {
            list-style: none;
            padding: 0
        }

            .ft-ul li {
                margin-bottom: 7px
            }

            .ft-ul a {
                color: var(--t3);
                font-size: 12px;
                transition: var(--tr)
            }

                .ft-ul a:hover {
                    color: var(--t1)
                }

        .si-row {
            display: flex;
            gap: 7px;
            margin-top: 14px
        }

        .si {
            width: 34px;
            height: 34px;
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: var(--r1);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--t3);
            transition: var(--tr);
            font-size: 13px
        }

            .si:hover {
                background: var(--elevated);
                color: var(--green);
                border-color: var(--green)
            }

        .ft-bot {
            border-top: 1px solid var(--border);
            padding-top: 18px;
            margin-top: 32px;
            font-size: 11px;
            color: var(--t3);
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 6px
        }

        @@media(max-width:768px) {
            .week-summary {
                grid-template-columns: repeat(2,1fr)
            }

            .fx-right .fx-stadium {
                display: none
            }

            .fx-name {
                font-size: 13px
            }
        }

        @@media(max-width:500px) {
            .fx-teams {
                gap: 4px
            }

            .fx-name {
                font-size: 12px
            }

            .fx-logo {
                width: 22px;
                height: 22px
            }

            .week-summary {
                grid-template-columns: repeat(2,1fr);
                gap: 8px
            }

            .ws-num {
                font-size: 20px
            }
        }
    </style>
</head>
<body>

    <!-- NAVBAR -->


    <!-- PAGE HEADER -->
    <section class="pg-head">
        <div class="wrap">
            <div class="row align-items-end">
                <div class="col-lg-7">
                    <div class="pg-badge"><i class="bi bi-trophy-fill"></i> Premier League</div>
                    <h1 class="pg-title">
                        Hafta <span style="color:var(--blue)">@weekNum</span> Fikstürü
                    </h1>
                    <p class="pg-sub">
                        @if (fixtures.Any())
                        {
                            var first = fixtures.Min(f => f.MatchDate);
                            var last = fixtures.Max(f => f.MatchDate);
                            <text>
                                @first.ToString("dd MMM", new System.Globalization.CultureInfo("tr-TR"))
                                –
                                @last.ToString("dd MMM yyyy", new System.Globalization.CultureInfo("tr-TR"))
                                &nbsp;·&nbsp; @fixtures.Count Maç
                            </text>
                        }
                        else
                        {
                            <text>@week · Maç bulunamadı</text>
                        }
                    </p>
                    <div class="week-nav">
                        <a href="/Fixture/Index?week=@(prevWeek).Hafta" class="wn-btn">
                            <i class="bi bi-chevron-left"></i> Hafta @prevWeek
                        </a>
                        <div class="wn-cur">Hafta @weekNum</div>
                        <a href="/Fixture/Index?week=@(nextWeek).Hafta" class="wn-btn">
                            Hafta @nextWeek <i class="bi bi-chevron-right"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- MAIN -->
    <main>
        <div class="wrap">
            <div class="content">

                <!-- WEEK SUMMARY -->
                @if (summary != null)
                {
                    <div class="week-summary">
                        <div class="ws-card">
                            <div class="ws-num" style="color:var(--blue)">@summary.TotalMatch</div>
                            <div class="ws-lbl">Toplam Maç</div>
                        </div>
                        <div class="ws-card">
                            <div class="ws-num" style="color:var(--live)">@summary.LiveMatch</div>
                            <div class="ws-lbl">Canlı</div>
                        </div>
                        <div class="ws-card">
                            <div class="ws-num" style="color:var(--green)">@summary.FinishedMatch</div>
                            <div class="ws-lbl">Biten</div>
                        </div>
                        <div class="ws-card">
                            <div class="ws-num" style="color:var(--t2)">@summary.UpcomingMatch</div>
                            <div class="ws-lbl">Yaklaşan</div>
                        </div>
                    </div>
                }

                <!-- GROUPED BY DAY -->
                @if (!fixtures.Any())
                {
                    <div class="empty-state">
                        <i class="bi bi-calendar-x"></i>
                        <p>Bu haftaya ait maç bulunamadı.</p>
                    </div>
                }

                @foreach (var group in grouped)
                {
                    var dayName = DayName(group.Key);
                    var dateStr = group.Key.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"));
                    var count = group.Count();

                    <div class="day-group">
                        <div class="day-header">
                            <span class="day-title">@dayName</span>
                            <span class="day-date">@dateStr</span>
                            <div class="day-line"></div>
                            <span class="day-cnt">@count Maç</span>
                        </div>

                        @foreach (var f in group.OrderBy(x => x.MatchDate))
                        {
                            bool isLive = f.Status == "Live";
                            bool isFinished = f.Status == "Finished";
                            bool hasScore = f.HomeScore.HasValue && f.AwayScore.HasValue;
                            string cardCls = f.IsFeatured ? "featured" : (isLive ? "live-card" : "");

                            <a href="/Match/MatchDetail/@f.MatchId" class="fx-card @cardCls">
                                @if (f.IsFeatured)
                                {
                                    <div class="fx-top-badge"></div>
                                }
                                @if (isLive && !f.IsFeatured)
                                {
                                    <div class="fx-live-badge"></div>
                                }

                                <div class="fx-inner">
                                    <!-- Saat / Durum -->
                                    <div class="fx-time-col">
                                        @if (isLive)
                                        {
                                            <div class="fx-time live-time">@f.Minute'</div>
                                            <div class="fx-live-tag">CANLI</div>
                                        }
                                        else if (isFinished)
                                        {
                                            <div class="fx-time">@f.MatchDate.ToString("HH:mm")</div>
                                            <div class="fx-status-tag">MS</div>
                                        }
                                        else
                                        {
                                            <div class="fx-time">@f.MatchDate.ToString("HH:mm")</div>
                                            @if (f.IsFeatured)
                                            {
                                                <div class="fx-top-tag">★ TOP</div>
                                            }
                                        }
                                    </div>

                                    <div class="fx-divider"></div>

                                    <!-- Takımlar & Skor -->
                                    <div class="fx-teams">
                                        <div class="fx-team-home">
                                            <span class="fx-name home">@f.HomeTeam</span>
                                            <div class="fx-logo">
                                                @if (!string.IsNullOrEmpty(f.HomeLogoUrl))
                                                {
                                                    <img src="@f.HomeLogoUrl" alt="@f.HomeTeam" onerror="this.style.display='none'" />
                                                }
                                                else
                                                {
                                                    <span>@(f.HomeTeam?.Length >= 3 ? f.HomeTeam[..3].ToUpper() : f.HomeTeam)</span>
                                                }
                                            </div>
                                        </div>

                                        @if (hasScore)
                                        {
                                            <div class="score-block">
                                                <div class="score-txt @(isLive?"live-score":"")">
                                                    @f.HomeScore – @f.AwayScore
                                                </div>
                                                @if (isLive)
                                                {
                                                    <div class="score-min">@f.Minute'</div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="vs-block">
                                                <span class="vs-text">VS</span>
                                            </div>
                                        }

                                        <div class="fx-team-away">
                                            <div class="fx-logo">
                                                @if (!string.IsNullOrEmpty(f.AwayLogoUrl))
                                                {
                                                    <img src="@f.AwayLogoUrl" alt="@f.AwayTeam" onerror="this.style.display='none'" />
                                                }
                                                else
                                                {
                                                    <span>@(f.AwayTeam?.Length >= 3 ? f.AwayTeam[..3].ToUpper() : f.AwayTeam)</span>
                                                }
                                            </div>
                                            <span class="fx-name">@f.AwayTeam</span>
                                        </div>
                                    </div>

                                    <!-- Sağ: Stadyum -->
                                    <div class="fx-right">
                                        @if (!string.IsNullOrEmpty(f.Stadium))
                                        {
                                            <span class="fx-stadium">
                                                <i class="bi bi-geo-alt" style="font-size:10px;margin-right:3px"></i>@f.Stadium
                                            </span>
                                        }
                                    </div>
                                </div>
                            </a>
                        }
                    </div>
                }

            </div>
        </div>
    </main>

    <!-- FOOTER -->


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Mobile nav
            const tog = document.getElementById('tog');
            const mob = document.getElementById('mobMenu');
            tog.addEventListener('click', () => {
                mob.classList.toggle('open');
                tog.innerHTML = mob.classList.contains('open')
                    ? '<i class="bi bi-x-lg"></i>' : '<i class="bi bi-list"></i>';
            });
            // Navbar shadow
            window.addEventListener('scroll', () => {
                document.querySelector('.nb').style.boxShadow =
                    window.scrollY > 8 ? '0 4px 32px rgba(0,0,0,.7)' : '0 2px 24px rgba(0,0,0,.5)';
            });
            // Card animate
            document.querySelectorAll('.fx-card').forEach((c, i) => {
                c.style.opacity = '0';
                c.style.transform = 'translateY(10px)';
                setTimeout(() => {
                    c.style.transition = 'opacity .3s ease, transform .3s ease';
                    c.style.opacity = '1';
                    c.style.transform = 'translateY(0)';
                }, 40 + i * 50);
            });</script>
</body>
</html>

